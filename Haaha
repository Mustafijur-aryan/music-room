<!DOCTYPE html>
<html>
<head>

<title>🐱 Music Room</title>

<style>

body{
font-family:Arial;
text-align:center;
background:linear-gradient(135deg,#ff9a9e,#fad0c4);
padding:20px;
}

#chat{
background:white;
height:200px;
overflow:auto;
padding:10px;
border-radius:10px;
margin-top:20px;
}

input{
padding:10px;
border-radius:20px;
border:none;
}

button{
padding:10px 15px;
border:none;
border-radius:20px;
background:#ff4d4d;
color:white;
}

</style>

</head>

<body>

<h1>🐱 Music Room 🎧</h1>

<p>Only 2 people can listen together</p>

<input id="songInput" placeholder="Paste YouTube link">

<button onclick="changeSong()">Play</button>

<br><br>

<iframe id="player"
width="320"
height="180"
src=""
frameborder="0"
allow="autoplay"
allowfullscreen>
</iframe>

<div id="chat"></div>

<input id="msg" placeholder="Type message">

<button onclick="send()">Send</button>

<script type="module">

import { initializeApp } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-app.js";
import { getDatabase, ref, set, push, onValue } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-database.js";

const firebaseConfig = {
apiKey: "AIzaSyAARWGREEYiXXrLIDxGybuXeTQ47ruguXI",
authDomain: "listen-together-c1d2b.firebaseapp.com",
projectId: "listen-together-c1d2b",
storageBucket: "listen-together-c1d2b.firebasestorage.app",
messagingSenderId: "978393480942",
appId: "1:978393480942:web:0d73ea5eec72a412b5bdff",
measurementId: "G-FB6N25SGNM"
};

const app = initializeApp(firebaseConfig);
const db = getDatabase();

window.changeSong = function(){

let link=document.getElementById("songInput").value

let id=""

if(link.includes("watch?v=")){
id=link.split("watch?v=")[1]
}
else if(link.includes("youtu.be/")){
id=link.split("youtu.be/")[1]
}

set(ref(db,"song"),id)

}

onValue(ref(db,"song"),(snap)=>{

let id=snap.val()

if(id){

document.getElementById("player").src=
"https://www.youtube.com/embed/"+id+"?autoplay=1"

}

})

window.send=function(){

let text=document.getElementById("msg").value

push(ref(db,"chat"),text)

document.getElementById("msg").value=""

}

onValue(ref(db,"chat"),(snap)=>{

let data=snap.val()

let html=""

for(let i in data){

html+="<div>"+data[i]+"</div>"

}

document.getElementById("chat").innerHTML=html

})

</script>

</body>
</html>